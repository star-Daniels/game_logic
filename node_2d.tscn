[sub_resource type="TileSet" id="TileSet_q6r6c"]
sources/1 = SubResource("TileSetAtlasSource_0hol4")

[sub_resource type="GDScript" id="GDScript_0e48y"]
script/source = "extends CharacterBody2D

@export var speed = 100
@onready var animation = $animation as AnimatedSprite2D
var sprite_direction 

func _physics_process(delta):

	var direction = Vector2.ZERO
	
	if Input.is_action_pressed(\"ui_right\"):
		animation.play(\"walk_right\")
		direction.x = 1
		sprite_direction = \"ui_right\"
		
	elif Input.is_action_pressed(\"ui_left\"):
		animation.play(\"walk_left\")
		direction.x = -1
		sprite_direction = \"ui_left\"
		
	elif Input.is_action_pressed(\"ui_down\"):
		animation.play(\"walk_down\")
		direction.y = 1
		sprite_direction = \"ui_down\"
		
	elif Input.is_action_pressed(\"ui_up\"):
		animation.play(\"walk_up\")
		direction.y = -1
		sprite_direction = \"ui_up\"
		
	elif (sprite_direction == \"ui_up\"):
		animation.play(\"stop_up\")
		
	elif (sprite_direction == \"ui_down\"):
		animation.play(\"stop_down\")
		
	elif (sprite_direction == \"ui_right\"):
		animation.play(\"stop_right\")
		
	elif (sprite_direction == \"ui_left\"):
		animation.play(\"stop_left\")
	
	
	
		

	velocity = direction * speed
	move_and_slide()
"

[sub_resource type="CapsuleShape2D" id="CapsuleShape2D_epypp"]
